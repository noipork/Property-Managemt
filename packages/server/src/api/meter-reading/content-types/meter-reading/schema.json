{
  "kind": "collectionType",
  "collectionName": "meter_readings",
  "info": {
    "singularName": "meter-reading",
    "pluralName": "meter-readings",
    "displayName": "Meter Reading",
    "description": "Monthly meter readings for rooms"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "room": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::room.room"
    },
    "property": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::property.property"
    },
    "readingDate": {
      "type": "date",
      "required": true
    },
    "electricMeterValue": {
      "type": "decimal",
      "default": 0
    },
    "waterMeterValue": {
      "type": "decimal",
      "default": 0
    },
    "electricMeterPrev": {
      "type": "decimal",
      "default": 0
    },
    "waterMeterPrev": {
      "type": "decimal",
      "default": 0
    },
    "electricUnitsUsed": {
      "type": "decimal",
      "default": 0
    },
    "waterUnitsUsed": {
      "type": "decimal",
      "default": 0
    },
    "notes": {
      "type": "text"
    },
    "recordedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
