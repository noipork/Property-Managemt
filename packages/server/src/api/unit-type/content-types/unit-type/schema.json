{
  "kind": "collectionType",
  "collectionName": "unit_types",
  "info": {
    "singularName": "unit-type",
    "pluralName": "unit-types",
    "displayName": "Unit Type",
    "description": "Types of units within a property"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "unitType": {
      "type": "enumeration",
      "enum": [
        "studio",
        "br1",
        "br2",
        "br3",
        "br4",
        "penthouse",
        "shophouse",
        "office",
        "warehouse",
        "other"
      ],
      "default": "studio",
      "required": true
    },
    "quantity": {
      "type": "integer",
      "required": true,
      "min": 1,
      "default": 1
    },
    "area": {
      "type": "decimal"
    },
    "areaUnit": {
      "type": "string",
      "default": "sqm"
    },
    "price": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "THB"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "available",
        "occupied",
        "maintenance",
        "unavailable"
      ],
      "default": "available",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "property": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::property.property",
      "inversedBy": "unitTypes"
    }
  }
}
