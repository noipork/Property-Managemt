{
  "kind": "collectionType",
  "collectionName": "maintenance_messages",
  "info": {
    "singularName": "maintenance-message",
    "pluralName": "maintenance-messages",
    "displayName": "Maintenance Message",
    "description": "Messages/discussions for maintenance requests"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "message": {
      "type": "text",
      "required": true
    },
    "sender": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "maintenance": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::maintenance.maintenance",
      "inversedBy": "messages"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "isInternal": {
      "type": "boolean",
      "default": false
    },
    "isRead": {
      "type": "boolean",
      "default": false
    },
    "readAt": {
      "type": "datetime"
    }
  }
}
