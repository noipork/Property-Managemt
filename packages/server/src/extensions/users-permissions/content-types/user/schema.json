{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "plan": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::plan.plan",
      "inversedBy": "users"
    },
    "unitType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::unit-type.unit-type"
    },
    "roomNumber": {
      "type": "string"
    },
    "plainPassword": {
      "type": "string",
      "private": true
    },
    "registrationDate": {
      "type": "date"
    },
    "residencyStatus": {
      "type": "enumeration",
      "default": "reserved",
      "enum": [
        "reserved",
        "active",
        "nearlyExpired",
        "expired",
        "inactive"
      ]
    },
    "nextBillDate": {
      "type": "date"
    },
    "billings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::billing.billing",
      "mappedBy": "resident"
    },
    "payments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::payment.payment",
      "mappedBy": "resident"
    },
    "leases": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lease.lease",
      "mappedBy": "resident"
    },
    "maintenances": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::maintenance.maintenance",
      "mappedBy": "resident"
    },
    "notifications": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::notification.notification",
      "mappedBy": "recipient"
    },
    "property": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::property.property",
      "inversedBy": "owner"
    },
    "subscriptions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::subscription.subscription",
      "mappedBy": "user"
    },
    "activeSubscription": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::subscription.subscription"
    }
  }
}
